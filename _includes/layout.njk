<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ title + ' | ' + site.title if title else site.title }}</title>
    <meta name="description"
          content="{{ description | default(site.description) }}">
    <link rel="canonical" href="{{ site.url }}{{ page.url }}">
    <link rel="icon" href="/assets/favicon.ico">
    <meta property="og:title"
          content="{{ title + ' | ' + site.title if title else site.title }}">
    <meta property="og:description"
          content="{{ description | default(site.description) }}">
    <meta property="og:url" content="{{ site.url }}{{ page.url }}">
    <link rel="preload"
          href="/assets/fonts/AtkinsonHyperlegibleNextVF-Variable.woff2"
          as="font"
          type="font/woff2"
          crossorigin>
    <link rel="preload"
          href="/assets/fonts/SortsMillGoudy-Regular.woff2"
          as="font"
          type="font/woff2"
          crossorigin>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <div class="page-container">
      <header>
        <nav>
          <ul role="list">
            {% for item in collections.page | sort(false, false, "data.navOrder") %}
              <li>
                <a href="{{ item.url }}"
                   {% if page.url == item.url %} aria-current="page" {% elif page.url.startsWith(item.url) and item.url != "/" %} aria-current="true" {% endif %}>{{ item.data.title }}</a>
              </li>
            {% endfor %}
          </ul>
        </nav>
      </header>
      <main>
        <div class="title">
          <h1>{{ title }}</h1>
        </div>
        {{ content | safe }}
      </main>
      <footer>
        Copyright © {{ site.year }}
      </footer>
    </div>
  </body>
</html>
