<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="{{ description | default("Welcome to EthanBarrett.dev")}}">
    <link rel="stylesheet" href="/css/style.css" />
    <title>{{ title | default("EthanBarrett.dev") }}</title>
  </head>
  <body>
    <header>
        <nav>
            <ul>
               {% for page in collections.page | sort(false, false, "data.navOrder") %} 
               <li><a href="{{ page.url }}">{{ page.data.title }}</a></li>
               {% endfor %}
            </ul>
        </nav>
    <h1>{{ title }}</h1>
    </header>
    <main>
        {{ content | safe }}
    </main>
  </body>
</html>
